# VCFtools
# A set of tools written in Perl and C++ for working with VCF files, such as those generated by the 1000 Genomes Project.
#
# Project website: https://vcftools.github.io/

# base image: Ubuntu
FROM ubuntu:24.04

ENV VERSION="0.1.17"

# File Author / Maintainer
LABEL maintainer=anna.zhukova@pasteur.fr

RUN apt-get update --fix-missing \
    && apt-get install -y wget make gcc autoconf g++ pkg-config zlib1g-dev perl \
    && cd /usr/local/ \
    && wget -O vcftools-${VERSION}.tar.gz https://github.com/vcftools/vcftools/archive/v${VERSION}.tar.gz \
    && tar xvzf vcftools-${VERSION}.tar.gz \
    && rm -f vcftools-${VERSION}.tar.gz \
    && cd /usr/local/vcftools-${VERSION} \
    && ./autogen.sh \
    && ./configure \
    && make \
    && make install \
    && cd /usr/local \
    && rm -rf vcftools-${VERSION} \
    && apt-get remove -y wget make gcc autoconf g++ pkg-config zlib1g-dev \
    && apt-get autoremove -y \
    && apt-get clean \
    && rm -rf /var/lib/apt/lists/* \
    && mkdir /pasteur

ENTRYPOINT ["vcftools"]